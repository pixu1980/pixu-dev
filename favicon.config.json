{
	"masterPicture": "./src/assets/images/profile.png",
	"iconsPath": "/",
	"design": {
		"ios": {
			"pictureAspect": "backgroundAndMargin",
			"backgroundColor": "#1c8682",
			"margin": "0%",
			"assets": {
				"ios6AndPriorIcons": true,
				"ios7AndLaterIcons": true,
				"precomposedIcons": true,
				"declareOnlyDefaultIcon": true
			},
			"appName": "pixu.dev"
		},
		"desktopBrowser": {
			"design": "background",
			"backgroundColor": "#1c8682",
			"backgroundRadius": 0.45,
			"imageScale": 1
		},
		"windows": {
			"pictureAspect": "noChange",
			"backgroundColor": "#1c8682",
			"onConflict": "override",
			"assets": {
				"windows80Ie10Tile": false,
				"windows10Ie11EdgeTiles": {
					"small": false,
					"medium": true,
					"big": false,
					"rectangle": false
				}
			},
			"appName": "pixu.dev"
		},
		"androidChrome": {
			"pictureAspect": "noChange",
			"themeColor": "#1c8682",
			"manifest": {
				"name": "pixu.dev",
				"startUrl": "https://pixu.dev",
				"display": "standalone",
				"orientation": "notSet",
				"onConflict": "override",
				"declared": true
			},
			"assets": {
				"legacyIcon": true,
				"lowResolutionIcons": false
			}
		},
		"safariPinnedTab": {
			"pictureAspect": "silhouette",
			"themeColor": "#1c8682"
		}
	},
	"settings": {
		"compression": 1,
		"scalingAlgorithm": "Mitchell",
		"errorOnImageTooSmall": false,
		"readmeFile": true,
		"htmlCodeFile": true,
		"usePathAsIs": false
	},
	"versioning": {
		"paramName": "v",
		"paramValue": "1"
	}
}
